{
  "description": "Boundary value and invalid input matrix for cross-language testing. All 8 languages must produce identical results.",
  "version": "1.0",
  "categories": {
    "v4_boundary_valid": {
      "description": "Valid IPv4 addresses that MUST parse successfully",
      "cases": [
        {"ip": "0.0.0.0", "label": "V4-zero", "note": "Cloudflare DNS, historical bug"},
        {"ip": "255.255.255.255", "label": "V4-broadcast"},
        {"ip": "127.0.0.1", "label": "V4-loopback"},
        {"ip": "10.0.0.1", "label": "V4-private-class-a"},
        {"ip": "10.255.255.255", "label": "V4-private-class-a-end"},
        {"ip": "172.16.0.1", "label": "V4-private-class-b-start"},
        {"ip": "172.31.255.255", "label": "V4-private-class-b-end"},
        {"ip": "192.168.1.1", "label": "V4-private-class-c"},
        {"ip": "169.254.1.1", "label": "V4-link-local"},
        {"ip": "192.0.2.1", "label": "V4-documentation"},
        {"ip": "224.0.0.1", "label": "V4-multicast"},
        {"ip": "240.0.0.1", "label": "V4-reserved"}
      ]
    },
    "v4_invalid": {
      "description": "Invalid IPv4 addresses that MUST be rejected (return None/empty)",
      "cases": [
        {"ip": "", "label": "V4-empty"},
        {"ip": "1.2.3", "label": "V4-too-few-octets"},
        {"ip": "1.2.3.4.5", "label": "V4-too-many-octets"},
        {"ip": "114..114.114.114", "label": "V4-double-dot"},
        {"ip": ".1.2.3.4", "label": "V4-leading-dot"},
        {"ip": "1.2.3.4.", "label": "V4-trailing-dot"},
        {"ip": "256.1.2.3", "label": "V4-octet-overflow"},
        {"ip": "-1.2.3.4", "label": "V4-negative"},
        {"ip": "a.b.c.d", "label": "V4-non-numeric"},
        {"ip": "1.2.3.4:80", "label": "V4-with-port"},
        {"ip": "0162.0162.0162.0162", "label": "V4-leading-zero"},
        {"ip": "0x72.0x72.0x72.0x72", "label": "V4-hex-format"}
      ]
    },
    "v4_parser_dependent": {
      "description": "IPs where behavior varies by parser — all languages must agree with each other",
      "cases": [
        {"ip": " 114.114.114.114", "label": "V4-leading-space", "note": "Python trims whitespace, some parsers reject"},
        {"ip": "114.114.114.114 ", "label": "V4-trailing-space", "note": "Python trims whitespace, some parsers reject"}
      ]
    },
    "v6_boundary_valid": {
      "description": "Valid IPv6 addresses that MUST parse successfully",
      "cases": [
        {"ip": "::1", "label": "V6-loopback"},
        {"ip": "::", "label": "V6-unspecified"},
        {"ip": "2001:4860:4860::8888", "label": "V6-google-dns"},
        {"ip": "2408:8000:9000::1", "label": "V6-china-unicom"},
        {"ip": "2606:4700:4700::1111", "label": "V6-cloudflare"},
        {"ip": "fe80::1", "label": "V6-link-local"},
        {"ip": "ff02::1", "label": "V6-multicast"},
        {"ip": "2002::1", "label": "V6-6to4"},
        {"ip": "fd00::1", "label": "V6-unique-local"},
        {"ip": "2001:db8::1", "label": "V6-documentation"},
        {"ip": "ffff:ffff:ffff:ffff:ffff:ffff:ffff:ffff", "label": "V6-all-ones"},
        {"ip": "0000:0000:0000:0000:0000:0000:0000:0001", "label": "V6-full-form-loopback"}
      ]
    },
    "v6_embedded_v4": {
      "description": "IPv4-mapped/translated IPv6 addresses - behavior depends on parser",
      "cases": [
        {"ip": "::ffff:114.114.114.114", "label": "V6-mapped-v4", "note": "Mapped address, most parsers reject or treat as V4"},
        {"ip": "::ffff:8.8.8.8", "label": "V6-mapped-google", "note": "Mapped address"},
        {"ip": "::ffff:0:114.114.114.114", "label": "V6-translated-v4", "note": "Translated address, typically rejected"}
      ]
    },
    "v6_invalid": {
      "description": "Invalid IPv6 addresses that MUST be rejected (return None/empty)",
      "cases": [
        {"ip": "", "label": "V6-empty"},
        {"ip": "1:2:3:4:5:6:7:8:9", "label": "V6-too-many-groups"},
        {"ip": "2001::1::", "label": "V6-double-compress"},
        {"ip": "2001:gggg::1", "label": "V6-non-hex"},
        {"ip": "fe80::1%eth0", "label": "V6-zone-id"},
        {"ip": "[::1]", "label": "V6-bracketed"},
        {"ip": "[::1]:80", "label": "V6-bracketed-with-port"},
        {"ip": "1::2::3", "label": "V6-multiple-compress"}
      ]
    }
  },
  "expected_behavior": {
    "valid_ips": "All languages return identical pipe string for same DB",
    "invalid_ips": "All languages return None/empty string, never crash",
    "embedded_v4": "Consistency: all languages treat ::ffff:x.x.x.x the same way"
  }
}
